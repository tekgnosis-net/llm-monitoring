# ============================================================================
# Monitoring host configuration. Copy to .env and fill in.
#   cp .env.example .env
# .env is git-ignored — it is the ONLY place secrets live.
# ============================================================================

# --- What to monitor ---------------------------------------------------------
# Comma-separated "name:ip" (or "name:ip:port") entries. "name" becomes the
# `server` label; ports default per backend and can be overridden per entry.
# A host may appear in more than one list. Leave a list empty if unused.

# vLLM endpoints (OpenAI-compatible /metrics on port 8000 by default).
VLLM_HOSTS=gpu-a:192.168.1.50,gpu-b:192.168.1.51

# llama.cpp endpoints (llama-server started with --metrics; port 8080 default).
# Override the port per entry when needed, e.g. gpu-d:192.168.1.53:8081
LLAMACPP_HOSTS=gpu-c:192.168.1.52

# Every GPU host running the DCGM exporter agent (GPU telemetry on :9400).
# Usually the union of the LLM hosts above.
GPU_HOSTS=gpu-a:192.168.1.50,gpu-b:192.168.1.51,gpu-c:192.168.1.52

# Servers whose workload is batch / long-context (e.g. Hindsight consolidation).
# These get tier=batch: they keep queue / KV / decode-speed (TPOT) alerts but are
# EXEMPT from the interactive e2e-latency and TTFT alerts (long prefills are normal
# there and would false-page). Names must match those in the *_HOSTS lists.
# Anything not listed defaults to tier=interactive. Comma-separated; may be empty.
BATCH_SERVERS=

# --- Grafana -----------------------------------------------------------------
# Required — compose fails to start if unset (no insecure default).
GF_ADMIN_PASSWORD=changeme

# --- Alertmanager SMTP (e.g. mailcow) ----------------------------------------
# Port 587 + STARTTLS is the recommended submission path.
SMTP_SMARTHOST=mail.example.net:587
SMTP_FROM=alerts@example.net
SMTP_USER=alerts@example.net
SMTP_PASSWORD=changeme                    # injected as a runtime Docker secret
ALERT_EMAIL_DEFAULT=ops@example.net       # warnings + resolved notices
ALERT_EMAIL_CRITICAL=admin@example.net    # critical alerts
